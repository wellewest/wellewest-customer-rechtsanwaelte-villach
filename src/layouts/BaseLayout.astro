---
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'

interface Props {
  title?: string
  description?: string
  ogImage?: string
}

const { title, description, ogImage } = Astro.props
const fullTitle = title
  ? `${title} | Reif und Partner Rechtsanwälte Villach`
  : 'Reif und Partner Rechtsanwälte | Villach'
const finalDescription = description ||
  'Wir kümmern uns um Ihr Recht. Reif und Partner — Ihr Rechtsanwalt in Villach. Mag. Herbert Steinwandter und Team.'
---
<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={finalDescription} />

    {/* DEMO: vor Suchmaschinen verstecken */}
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="googlebot" content="noindex, nofollow" />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Preload key fonts */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  main { min-height: calc(100vh - 200px); }
</style>
