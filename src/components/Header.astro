---
import { practiceAreas } from '../lib/content'

const pathname = Astro.url.pathname
const isActive = (href: string) => pathname === href || pathname.startsWith(href + '/')
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand">
      <span class="brand__name">Reif und Partner</span>
      <span class="brand__sub">Rechtsanwälte · Villach</span>
    </a>

    <nav class="nav-desktop" aria-label="Hauptnavigation">
      <ul>
        <li><a href="/" class:list={[{ active: pathname === '/' }]}>Startseite</a></li>
        <li class="has-submenu">
          <a href="#leistungen" aria-haspopup="true">Leistungen <span aria-hidden="true">▾</span></a>
          <div class="submenu">
            {practiceAreas.map((p) => (
              <a href={`/${p.slug}`} class:list={[{ active: isActive(`/${p.slug}`) }]}>{p.title}</a>
            ))}
          </div>
        </li>
        <li><a href="/kontakt" class:list={[{ active: isActive('/kontakt') }]}>Kontakt</a></li>
        <li><a href="/anfahrt" class:list={[{ active: isActive('/anfahrt') }]}>Anfahrt</a></li>
      </ul>
    </nav>

    <button class="hamburger" aria-label="Menü öffnen" aria-expanded="false" data-mobile-toggle>
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" data-mobile-menu>
    <nav>
      <a href="/">Startseite</a>
      <p class="mobile-menu__heading">Leistungen</p>
      {practiceAreas.map((p) => (
        <a href={`/${p.slug}`}>{p.title}</a>
      ))}
      <p class="mobile-menu__heading">Service</p>
      <a href="/kontakt">Kontakt</a>
      <a href="/anfahrt">Anfahrt</a>
      <a href="/impressum">Impressum</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-divider);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    gap: 2rem;
  }

  .brand {
    display: flex;
    flex-direction: column;
    color: var(--color-primary);
    text-decoration: none;
    line-height: 1.1;
  }
  .brand__name {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand__sub {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: 2px;
  }

  .nav-desktop {
    display: flex;
  }
  .nav-desktop ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
    align-items: center;
  }
  .nav-desktop a {
    display: inline-block;
    padding: 0.6rem 0.9rem;
    color: var(--color-primary);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-desktop a:hover, .nav-desktop a.active {
    color: var(--color-accent);
  }

  .has-submenu {
    position: relative;
  }
  .submenu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    border: 1px solid var(--color-divider);
    box-shadow: 0 12px 32px rgba(14,31,61,0.12);
    padding: 0.5rem 0;
    min-width: 240px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.15s ease, visibility 0.15s ease;
  }
  .has-submenu:hover .submenu, .has-submenu:focus-within .submenu {
    opacity: 1;
    visibility: visible;
  }
  .submenu a {
    display: block;
    padding: 0.5rem 1.25rem;
    font-size: 0.9rem;
  }
  .submenu a:hover { background: var(--color-bg-alt); }

  .hamburger {
    display: none;
    background: none;
    border: 0;
    width: 30px;
    height: 30px;
    cursor: pointer;
    padding: 0;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
  }
  .hamburger span {
    display: block;
    height: 2px;
    background: var(--color-primary);
    transition: transform 0.2s ease;
  }

  .mobile-menu {
    display: none;
    position: fixed;
    inset: 60px 0 0 0;
    background: #fff;
    overflow-y: auto;
    padding: 1.5rem;
    z-index: 99;
  }
  .mobile-menu nav { display: flex; flex-direction: column; gap: 0.25rem; }
  .mobile-menu a {
    padding: 0.85rem 0;
    color: var(--color-primary);
    font-size: 1rem;
    font-weight: 500;
    border-bottom: 1px solid var(--color-divider);
    text-decoration: none;
  }
  .mobile-menu__heading {
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin: 1.5rem 0 0.25rem;
    font-weight: 600;
  }
  .mobile-menu.is-open { display: block; }

  @media (max-width: 1024px) {
    .nav-desktop { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector('[data-mobile-toggle]')
  const menu = document.querySelector('[data-mobile-menu]')
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('is-open')
    toggle.setAttribute('aria-expanded', String(!!isOpen))
  })
</script>
